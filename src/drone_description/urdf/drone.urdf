<?xml version="1.0"?>
<robot name="drone">
  <link name="base_link">
    <visual><geometry><box size="0.35 0.35 0.1"/></geometry></visual>
    <collision><geometry><box size="0.35 0.35 0.1"/></geometry></collision>
    <inertial><mass value="1.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/></inertial>
  </link>
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.05" length="0.1"/></geometry></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/><origin xyz="0 0 0.1"/>
  </joint>
  <gazebo reference="lidar_link">
    <sensor name="laser" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan><horizontal><samples>640</samples><resolution>1</resolution><min_angle>-3.14</min_angle><max_angle>3.14</max_angle></horizontal></scan>
        <range><min>0.1</min><max>10.0</max></range>
      </lidar>
    </sensor>
  </gazebo>
</robot>